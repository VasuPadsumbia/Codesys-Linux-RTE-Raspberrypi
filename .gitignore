# Build artifacts
build/
downloads/
sstate-cache/
tmp/

# Build and test logs (keep directory, ignore log files)
logs/*.log

# Python
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
.eggs/

# Built images — copied here by cclrte.sh after successful build
data/output/

# CODESYS closed-license runtime packages
# Place these in data/ before building (not tracked in git — binary blobs)
# Obtain from: CODESYS IDE → Help → Install CODESYS Control for Linux
data/*.deb
data/*.ipk

# Xenomai meta-layer (obtain separately — see kas/rpi5-xenomai.yml)
layers/meta-xenomai/

# Site-specific config (contains WiFi passwords and SSH keys)
config/site.conf

# Generated bitbake conf — written by cclrte.sh at build time from site.conf
kas/.cclrte-packages.conf
kas/.cclrte-pkgs-overlay.yml

# Yocto
*.lock

# Editor
.vscode/settings.json
.idea/
*.swp
.vscode/

*~
.DS_Store
.gitignore
logs/

# The cloned Yocto layers (obtain separately — see kas/)
meta-openembedded/
meta-raspberrypi/
meta-realtime/
poky/
.*/