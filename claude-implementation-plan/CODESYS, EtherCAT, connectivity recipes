FILE 2: /home/vasu-hdd/yocto-gateway-rt/layers/meta-cclrte/recipes-codesys/codesys-control/files/CODESYSControl.cfg

Complete CODESYS Control for Linux configuration file. INI format with sections:

[SysProcess]
; CPU affinity - CPU3 only (bitmask 0x08 = CPU3)
; With PREEMPT_RT SCHED_FIFO, CODESYS tasks preempt all non-RT
SysCPUAffinity=0x08
; Real-time scheduling
SchedPolicy=SCHED_FIFO
SchedPriority=80
; Lock all memory pages to prevent page faults during scan cycle
MemLock=YES
; Stack size for tasks
StackSize=1048576

[SysEthernet]
; Ethernet adapter for CODESYS programming port
; eth0 is the dedicated CODESYS port (192.168.1.100)
Adapter.0.Name=eth0
Adapter.0.Mode=codesys

[SysSocket]
; Gateway port for CODESYS IDE connection
HostName=0.0.0.0
Port=1217

[CmpGateway]
; Allow remote programming via eth0
ServerType=1

[SysFile]
; PlcLogic boot project location
BootprojectPath=/var/opt/codesys/PlcLogic/

[SysCom]
; Serial ports available (RS485 via UART0 after BT disabled)
Port.0.Name=/dev/ttyAMA0

[CmpEthercat]
; EtherCAT master via IgH master - uses separate NIC (eth1 or dedicated)
; EtherCAT port is configured in ethercat.conf
MasterType=IghEthercat

[CmpOPCUA]
; OPC UA server embedded in CODESYS
Port=4840
MaxConnections=10

[SysLog]
LogPath=/var/log/codesys/
LogLevel=WARNING

