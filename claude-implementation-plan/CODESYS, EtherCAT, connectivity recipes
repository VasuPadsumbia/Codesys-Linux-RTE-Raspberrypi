FILE 3: /home/vasu-hdd/yocto-gateway-rt/layers/meta-cclrte/recipes-codesys/codesys-control/files/codesyscontrol.service

Complete systemd unit:
[Unit]
Description=CODESYS Control for Linux SL Runtime
Documentation=https://store.codesys.com
After=network.target rt-setup.service ethercat.service
Wants=ethercat.service
Requires=rt-setup.service

[Service]
Type=forking
PIDFile=/run/codesys/codesyscontrol.pid
ExecStartPre=/usr/sbin/codesys-setup.sh
ExecStart=/opt/codesys/bin/codesyscontrol -d -c /etc/CODESYSControl.cfg
ExecStop=/opt/codesys/bin/codesyscontrol -k
Restart=on-failure
RestartSec=5s
# RT scheduling - will be overridden by rt-setup.sh but set here as default
CPUSchedulingPolicy=fifo
CPUSchedulingPriority=80
# CPU3 affinity
CPUAffinity=3
# Memory lock
LimitMEMLOCK=infinity
LimitNOFILE=65536
LimitSTACK=8388608
# Runtime dir
RuntimeDirectory=codesys
RuntimeDirectoryMode=0755
# Watchdog ping
WatchdogSec=10s
NotifyAccess=main

[Install]
WantedBy=multi-user.target

