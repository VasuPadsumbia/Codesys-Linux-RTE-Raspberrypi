# IO-Link Master Configuration
# CCLRTE: IO-Link runs on SPI interface (SPI0 via GPIO)

# IO-Link master port configuration
# Port hardware: SPI0 (GPIO 8-11) + GPIO for port power/DI
[master]
transport=spi
spi_device=/dev/spidev0.0
spi_speed=4000000
# Number of IO-Link ports (depends on HAT)
num_ports=4
# Cycle time in microseconds (min 400µs per spec)
min_cycle_time=400

[port1]
enabled=true
mode=AUTOCOM  # Auto-detect: COM1(4.8kbps), COM2(38.4kbps), COM3(230.4kbps)

[port2]
enabled=true
mode=AUTOCOM

[port3]
enabled=false

[port4]
enabled=false

