# PROFINET RT Configuration
# CCLRTE: PROFINET device mode (for controller/master, use CODESYS PROFINET SL addon)

[device]
# Station name (must match GSD file)
station_name=cclrte-plc
# Device identity
vendor_id=0x0001
device_id=0x0001
oem_vendor_id=0x0000
oem_device_id=0x0000

[network]
# Network interface for PROFINET
# Must be separate from CODESYS programming port (eth0)
interface=eth1
# PROFINET uses its own IP assignment via DCP
enable_dcp=true
# RT cycle time (microseconds) - PROFINET RT Class 2
rt_cycle_time=1000

[slots]
# Configure I/O slots based on connected hardware
# Slot 0: DAP (Device Access Point - always present)
slot0_module=DAP

