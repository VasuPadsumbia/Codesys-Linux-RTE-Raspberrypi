# eth0 — CODESYS programming port (static IP) + SSH access
# CODESYS IDE connects here on port 1217.
# SSH is also available on this interface (sshd listens on all interfaces).
# Primary management interface is wlan0; eth0 is for lab bench / wired access.

[Match]
Name=eth0

[Network]
Address=192.168.2.100/24
Gateway=192.168.2.1
DNS=8.8.8.8
Description=CODESYS Programming Port

[Link]
# Disable power management on CODESYS port — latency critical
WakeOnLan=off
